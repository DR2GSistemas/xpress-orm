{
    "name": "dr2gsistemas/xpress-orm",
    "description": "ORM ligero para PHP 8.4 con atributos, relaciones y auto-migrate para MariaDB",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "orm",
        "database",
        "mariadb",
        "mysql",
        "repository",
        "entity",
        "php8"
    ],
    "require": {
        "php": "^8.4",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Xpress\\Orm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xpress\\Orm\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
